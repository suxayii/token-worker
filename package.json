{
  "name": "token-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker for License/UUID Verification using D1 Database",
  "main": "worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create token-worker-db",
    "db:init:local": "wrangler d1 execute token-worker-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute token-worker-db --remote --file=./schema.sql"
  },
  "keywords": [
    "cloudflare",
    "worker",
    "d1",
    "license",
    "verification"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
